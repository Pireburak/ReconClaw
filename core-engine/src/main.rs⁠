use clap::Parser;
use serde::Serialize;
use serde_json::json;

#[derive(Parser, Debug)]
#[command(author, version, about, long_about = None)]
struct Args {
    #[arg(short, long)]
    target: String,
}

// JSON olarak dışa aktarılacak veri yapısı
#[derive(Serialize)]
struct ScanResult {
    target: String,
    status: String,
    open_ports: Vec<u16>,
}

#[tokio::main]
async fn main() {
    let args = Args::parse();
    
    // Simülasyon: Tarama yapılmış ve bu portlar açık bulunmuş gibi yapıyoruz
    let simulated_open_ports = vec![80, 443, 8080];
    
    let result = ScanResult {
        target: args.target,
        status: "success".to_string(),
        open_ports: simulated_open_ports,
    };

    // Veriyi JSON'a çevir ve sadece JSON'u ekrana bas (Python buradan okuyacak)
    let json_output = json!(result);
    println!("{}", json_output.to_string());
}
